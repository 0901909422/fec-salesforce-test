                      type="String"
                      label="Display Mode"
                      description="Chọn loại record archive cần hiển thị: Interactions (I-/O-) cho tab All Interactions, hoặc Service Cases (S-) cho tab All Service Cases."
                      datasource="interactions,serviceCases"
                      default="interactions"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
