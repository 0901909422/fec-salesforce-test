<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>FEC_Restrict_Update_Code</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    NOT(ISNEW()),
    ISCHANGED(  FEC_Code__c )
)</errorConditionFormula>
    <errorDisplayField>FEC_Code__c</errorDisplayField>
    <errorMessage>Cannot edit field after creation</errorMessage>
</ValidationRule>
