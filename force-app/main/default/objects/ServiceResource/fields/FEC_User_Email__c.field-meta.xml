<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>FEC_User_Email__c</fullName>
    <description>Hiển thị Email ID
trường custom để hiển thị email của User theo yêu cầu</description>
    <externalId>false</externalId>
    <formula>LEFT(RelatedRecord.Email,FIND(&quot;@&quot;, RelatedRecord.Email) - 1)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>User Email</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
