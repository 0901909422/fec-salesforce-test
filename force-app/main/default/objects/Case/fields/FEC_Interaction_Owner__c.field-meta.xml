<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>FEC_Interaction_Owner__c</fullName>
    <description>email của chủ sở hữu (bỏ đuôi) hoặc tên Queue nếu người sở hữu Interaction là Queue</description>
    <externalId>false</externalId>
    <formula>IF( RecordType.Name = &apos;Interaction&apos;,(IF(ISBLANK(Owner:Queue.Id),
LEFT(Owner:User.Email,FIND(&quot;@&quot;, Owner:User.Email) - 1),
Owner:Queue.Name)),&apos;&apos;)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Interaction Owner</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
