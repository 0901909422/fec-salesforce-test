<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>FEC_Required_Header_Or_Footer</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    FEC_Footer__c  == null,
    FEC_Header__c == null
)</errorConditionFormula>
    <errorMessage>The header and footer fields are empty. Add something to at least one field, then try again.</errorMessage>
</ValidationRule>
