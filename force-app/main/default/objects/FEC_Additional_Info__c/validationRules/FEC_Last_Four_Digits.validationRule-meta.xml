<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>FEC_Last_Four_Digits</fullName>
    <active>true</active>
    <errorConditionFormula>NOT(REGEX(FEC_Last_4_Digits__c, &quot;^[0-9]{4}$&quot;))</errorConditionFormula>
    <errorDisplayField>FEC_Last_4_Digits__c</errorDisplayField>
    <errorMessage>Enter exactly 4 digits.</errorMessage>
</ValidationRule>
