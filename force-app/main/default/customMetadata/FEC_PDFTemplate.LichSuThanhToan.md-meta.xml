<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <label>Lịch Sử Thanh Toán</label>
    <protected>false</protected>
    <values>
        <field>FEC_Category__c</field>
        <value xsi:type="xsd:string">Thanh Toán</value>
    </values>
    <values>
        <field>FEC_Description__c</field>
        <value xsi:type="xsd:string">Template lịch sử thanh toán khoản vay với bảng chi tiết các lần thanh toán</value>
    </values>
    <values>
        <field>FEC_FileName__c</field>
        <value xsi:type="xsd:string">LichSuThanhToan</value>
    </values>
    <values>
        <field>FEC_HTMLBody__c</field>
        <value xsi:type="xsd:string">&lt;div style=&quot;font-size: 12pt; padding: 0 0; margin-left: 10px; margin-right: 10px;&quot;&gt;
    &lt;div style=&quot;text-align: right; margin-bottom: 40px; margin-right:5px;&quot;&gt;
        &lt;img src=&quot;/resource/Logo&quot; style=&quot;width: 250px; height: auto;&quot; /&gt;
    &lt;/div&gt;

    &lt;table style=&quot;width: 100%; border-collapse: collapse;&quot;&gt;
        &lt;tr&gt;
            &lt;td style=&quot;font-size: 18pt; text-align: center;&quot;&gt;
                &lt;b&gt;LỊCH SỬ THANH TOÁN&lt;/b&gt;
            &lt;/td&gt;
        &lt;/tr&gt;
        &lt;tr&gt;
            &lt;td style=&quot;text-align: center;&quot;&gt;
                &lt;em style=&quot;font-size: 11pt; font-style: italic;&quot;&gt;
                    (Thống kê đến ngày &lt;pega:reference name=&quot;pyWorkPage.CurrentDay&quot;&gt;&lt;/pega:reference&gt;/&lt;pega:reference name=&quot;pyWorkPage.CurrentMonth&quot;&gt;&lt;/pega:reference&gt;/&lt;pega:reference name=&quot;pyWorkPage.CurrentYear&quot;&gt;&lt;/pega:reference&gt;)
                &lt;/em&gt;
            &lt;/td&gt;
        &lt;/tr&gt;
    &lt;/table&gt;

    &lt;table style=&quot;width: 100%; border-collapse: collapse; margin-top: 30px; font-size: 11px; line-height:1.1;&quot;&gt;
        &lt;tr&gt;
            &lt;td style=&quot;width: 25%; vertical-align: top;&quot;&gt;&lt;b&gt;Khách Hàng:&lt;/b&gt;&lt;/td&gt;
            &lt;td style=&quot;width: 50%; vertical-align: top; text-align:center;&quot;&gt;
                &lt;pega:reference name=&quot;.pyWorkParty(Customer).FullName&quot;&gt;&lt;/pega:reference&gt;
            &lt;/td&gt;
        &lt;/tr&gt;
        &lt;tr&gt;
            &lt;td style=&quot;vertical-align: top;&quot;&gt;&lt;b&gt;Số Hợp Đồng:&lt;/b&gt;&lt;/td&gt;
            &lt;td style=&quot;vertical-align: top; text-align:center;&quot;&gt;
                &lt;pega:reference name=&quot;pyWorkPage.ContractNumber&quot;&gt;&lt;/pega:reference&gt;
            &lt;/td&gt;
        &lt;/tr&gt;
        &lt;tr&gt;
            &lt;td style=&quot;vertical-align: top;&quot;&gt;&lt;b&gt;Số CMND:&lt;/b&gt;&lt;/td&gt;
            &lt;td style=&quot;vertical-align: top; text-align:center;&quot;&gt;
                &lt;pega:reference name=&quot;pyWorkPage.NationalID&quot;&gt;&lt;/pega:reference&gt;
            &lt;/td&gt;
        &lt;/tr&gt;
    &lt;/table&gt;

    &lt;p style=&quot;text-align: right; font-size: 11pt; margin-top: 20px; font-style:italic;&quot;&gt;&lt;b&gt;&lt;em&gt;Đơn vị tính: VNĐ&lt;/em&gt;&lt;/b&gt;&lt;/p&gt;

    &lt;table style=&quot;width: 100%; border-collapse: collapse; border: 1px solid #aca899; font-size: 11pt;&quot;&gt;
        &lt;tr&gt;
            &lt;td style=&quot;border: 1px solid #aca899; text-align: center; padding: 5px; font-weight: bold; width: 16%&quot;&gt;Số thứ tự&lt;/td&gt;
            &lt;td style=&quot;border: 1px solid #aca899; text-align: center; padding: 5px; font-weight: bold; width: 42%&quot;&gt;
                Ngày Khách hàng thanh toán
            &lt;/td&gt;
            &lt;td style=&quot;border: 1px solid #aca899; text-align: center; padding: 5px; font-weight: bold; width: 42%&quot;&gt;
                Số tiền Khách hàng thanh toán
            &lt;/td&gt;
        &lt;/tr&gt;
        &lt;pega:forEach name=&quot;.SelectedAccount.LoanPaymentHistory&quot;&gt;
            &lt;tr&gt;
                &lt;td style=&quot;border: 1px solid #aca899; text-align: center; padding: 4px;&quot;&gt;
                    &lt;pega:reference name=&quot;$this.RemovalNote&quot;&gt;&lt;/pega:reference&gt;
                &lt;/td&gt;
                &lt;td style=&quot;border: 1px solid #aca899; text-align: center; padding: 4px;&quot;&gt;
                    &lt;pega:reference name=&quot;$this.BankAddress&quot;&gt;&lt;/pega:reference&gt;
                &lt;/td&gt;
                &lt;td style=&quot;border: 1px solid #aca899; text-align: center; padding: 4px;&quot;&gt;
                    &lt;pega:reference format=&quot;FormatCurrency&quot; name=&quot;$this.PaymentAmount&quot;&gt;&lt;/pega:reference&gt;
                &lt;/td&gt;
            &lt;/tr&gt;
        &lt;/pega:forEach&gt;
    &lt;/table&gt;
&lt;/div&gt;</value>
    </values>
    <values>
        <field>FEC_IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
    <values>
        <field>FEC_TemplateCode__c</field>
        <value xsi:type="xsd:string">LSTT</value>
    </values>
</CustomMetadata>
