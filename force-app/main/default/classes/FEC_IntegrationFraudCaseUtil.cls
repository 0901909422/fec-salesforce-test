public with sharing class FEC_IntegrationFraudCaseUtil {
    private static final Boolean DEBUG_LOG = true;
    
    /**
     * Represents a dynamic validation rule for a UI field that is configured
     * through master integration data.
     *
     * Each instance describes how a specific field should be validated and
     * interpreted by the fraud integration framework.
     */
    public class FieldRule {
        public String fieldName;     // FEC_Source_Id__c → UI field name
        public Boolean mandatory;    // FEC_Source_Is_Mandatory__c
        public String sourceType;    // Product, CaseType, Category...
        public String fieldType;     // string, number, list, boolean, datetime

         /**
         * Builds a FieldRule instance from a master data integration record.
         *
         * @param rec Configuration record defining the field's validation behavior.
         */
        public FieldRule(FEC_Master_Data_Integration__c rec) {
            this.fieldName  = rec.FEC_Source_Id__c;
            this.mandatory  = rec.FEC_Source_Is_Mandatory__c;
            this.sourceType = rec.FEC_Source_Type__c;
            this.fieldType  = rec.FEC_Source_Field_Type__c;
        }
    }


    /**
     * Wrapper response object for Fraud Case integration services.
     * 
     * This class is returned to LWC after calling either:
     *  - CreateFraudCase
     *  - CancelFraudCase
     *  - UpdateFraudCase
     * 
     * It provides a clean, strongly-typed response structure instead of using Map<String, Object>,
     * making client-side handling simpler, safer, and easier to maintain.
     */
    public class FraudCaseResponse {

        /**
         * Indicates whether the operation was processed successfully on Salesforce side.
         * true  = business flow completed successfully
         * false = error occurred (validation, integration failure, processing error)
         */
        @AuraEnabled public Boolean success;

        /**
         * Human-readable message returned to the UI.
         * Example: "Create Success", "Cancel Failed", or detailed error description from service.
         */
        @AuraEnabled public String message;

        /**
         * Fraud Case ID returned by the external Fraud system (e.g. FH-500070).
         * Only populated when the service responds successfully.
         */
        @AuraEnabled public String fraudCaseId;

        /**
         * Internal Service Case ID generated by Salesforce for tracking this integration request.
         * Used for logging, reconciliation, and troubleshooting.
         */
        @AuraEnabled public String serviceCaseId;

        /**
         * Numeric response code returned from external Fraud service.
         * Typically:
         *  1 = Success
         *  0 / other = Failure
         */
        @AuraEnabled public Integer responseCode;

        /**
         * Detailed description returned from external Fraud service.
         * Provides reason for success or failure.
         */
        @AuraEnabled public String responseDescription;
    }


    /**
     * Wrapper class that represents the result of extracting a fraud payload.
     *
     * This object separates the incoming request into two independent parts:
     *
     * 1. **detail**  – Business metadata from the request (JSON content),
     *                 with the embedded XML removed.
     *
     * 2. **xmlData** – The raw XML document extracted from the request,
     *                 cleaned and ready for DOM parsing.
     *
     * Keeping these separated simplifies processing, validation,
     * logging, and error handling in downstream services.
     */
    public class FraudExtractResult {
        /**
         * Clean business metadata extracted from the request.
         * Contains no XML content.
         */
        public Map<String, Object> detail;

         /**
         * Pure, normalized XML content extracted from the request.
         * Safe for DOM parsing.
         */
        public String xmlData;
    }
    
    // Mapping between file extensions and their corresponding MIME types
    // Key   : file extension (without dot)
    // Value : MIME type constant
    public static final Map<String, String> MIME_BY_EXT = new Map<String, String>{
        'pdf'  => FEC_FraudConstantCommon.MIME_PDF,
        'doc'  => FEC_FraudConstantCommon.MIME_DOC,
        'docx' => FEC_FraudConstantCommon.MIME_DOCX,
        'xls'  => FEC_FraudConstantCommon.MIME_XLS,
        'xlsx' => FEC_FraudConstantCommon.MIME_XLSX,
        'png'  => FEC_FraudConstantCommon.MIME_PNG,
        'jpg'  => FEC_FraudConstantCommon.MIME_JPG,
        'jpeg' => FEC_FraudConstantCommon.MIME_JPG
    };

    /**
     * Returns the MIME type based on a file extension.
     *
     * @param ext File extension (e.g. "pdf", "jpg", "docx")
     * @return Corresponding MIME type if found; otherwise returns MIME_DEFAULT
     */
    public static String getMimeType(String ext) {
        // If extension is null, empty, or whitespace → return default MIME type
        if (String.isBlank(ext)) {
            return FEC_FraudConstantCommon.MIME_DEFAULT;
        }

        // Convert extension to lowercase to make lookup case-insensitive
        // If the extension exists in the map, return its MIME type
        // Otherwise, fall back to the default MIME type
        return MIME_BY_EXT.get(ext.toLowerCase()) != null
            ? MIME_BY_EXT.get(ext.toLowerCase())
            : FEC_FraudConstantCommon.MIME_DEFAULT;
    }
    
    
