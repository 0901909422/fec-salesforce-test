         * false = error occurred (validation, integration failure, processing error)
         */
        @AuraEnabled public Boolean success;

        /**
         * Human-readable message returned to the UI.
         * Example: "Create Success", "Cancel Failed", or detailed error description from service.
         */
        @AuraEnabled public String message;

        /**
         * Fraud Case ID returned by the external Fraud system (e.g. FH-500070).
         * Only populated when the service responds successfully.
         */
        @AuraEnabled public String fraudCaseId;

        /**
         * Internal Service Case ID generated by Salesforce for tracking this integration request.
         * Used for logging, reconciliation, and troubleshooting.
         */
        @AuraEnabled public String serviceCaseId;

        /**
         * Numeric response code returned from external Fraud service.
         * Typically:
         *  1 = Success
         *  0 / other = Failure
         */
        @AuraEnabled public Integer responseCode;

        /**
         * Detailed description returned from external Fraud service.
         * Provides reason for success or failure.
         */
        @AuraEnabled public String responseDescription;
    }


