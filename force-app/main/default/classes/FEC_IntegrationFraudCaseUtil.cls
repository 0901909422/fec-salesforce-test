    /**
     * Wrapper class that represents the result of extracting a fraud payload.
     *
     * This object separates the incoming request into two independent parts:
     *
     * 1. **detail**  – Business metadata from the request (JSON content),
     *                 with the embedded XML removed.
     *
     * 2. **xmlData** – The raw XML document extracted from the request,
     *                 cleaned and ready for DOM parsing.
     *
     * Keeping these separated simplifies processing, validation,
     * logging, and error handling in downstream services.
     */
    public class FraudExtractResult {
        /**
         * Clean business metadata extracted from the request.
         * Contains no XML content.
         */
        public Map<String, Object> detail;

         /**
         * Pure, normalized XML content extracted from the request.
         * Safe for DOM parsing.
         */
        public String xmlData;
    }
    
    // Mapping between file extensions and their corresponding MIME types
    // Key   : file extension (without dot)
    // Value : MIME type constant
    public static final Map<String, String> MIME_BY_EXT = new Map<String, String>{
        'pdf'  => FEC_FraudConstantCommon.MIME_PDF,
        'doc'  => FEC_FraudConstantCommon.MIME_DOC,
        'docx' => FEC_FraudConstantCommon.MIME_DOCX,
        'xls'  => FEC_FraudConstantCommon.MIME_XLS,
        'xlsx' => FEC_FraudConstantCommon.MIME_XLSX,
        'png'  => FEC_FraudConstantCommon.MIME_PNG,
        'jpg'  => FEC_FraudConstantCommon.MIME_JPG,
        'jpeg' => FEC_FraudConstantCommon.MIME_JPG
    };

    /**
     * Returns the MIME type based on a file extension.
     *
     * @param ext File extension (e.g. "pdf", "jpg", "docx")
     * @return Corresponding MIME type if found; otherwise returns MIME_DEFAULT
     */
    public static String getMimeType(String ext) {
        // If extension is null, empty, or whitespace → return default MIME type
        if (String.isBlank(ext)) {
            return FEC_FraudConstantCommon.MIME_DEFAULT;
        }

        // Convert extension to lowercase to make lookup case-insensitive
        // If the extension exists in the map, return its MIME type
        // Otherwise, fall back to the default MIME type
        return MIME_BY_EXT.get(ext.toLowerCase()) != null
            ? MIME_BY_EXT.get(ext.toLowerCase())
            : FEC_FraudConstantCommon.MIME_DEFAULT;
    }
    
    
