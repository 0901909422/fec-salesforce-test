<?xml version="1.0" encoding="UTF-8"?>
<SharingRules xmlns="http://soap.sforce.com/2006/04/metadata">
    <sharingCriteriaRules>
        <fullName>FEC_Share_all_Interaction_Cases_to_Back_Office_user</fullName>
        <accessLevel>Read</accessLevel>
        <description>Chia sẻ toàn bộ bản ghi Interaction trên hệ thống cho toàn bộ người dùng thuộc Back Office (bao gồm SP, CC, QC, OM, CX)</description>
        <label>Share all Interaction Cases to Back Office user</label>
        <sharedTo>
            <group>FEC_CS_Back_Office</group>
        </sharedTo>
        <criteriaItems>
            <field>RecordTypeId</field>
            <operation>equals</operation>
            <value>Customer Case,Interaction,Internal Case</value>
        </criteriaItems>
        <includeRecordsOwnedByAll>true</includeRecordsOwnedByAll>
    </sharingCriteriaRules>
