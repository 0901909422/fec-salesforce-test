<aura:component implements="flexipage:availableForAllPageTypes,force:hasRecordId,lightning:isUrlAddressable"
    controller="FEC_NocRoutingAssignmentController"
    access="global">
    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="recordName" type="String" default="Routing Assignment" />
    <aura:attribute name="pageReference" type="Object" />
    <aura:attribute name="isEditMode" type="Boolean" default="false" />
    <aura:handler name="init" value="{!this}" action="{!c.init}" />

    <lightning:workspaceAPI aura:id="workspace" />

    <div class="ra-noc-wrapper">
        <!-- Header -->
        <div class="ra-noc-header-block">
            <div class="ra-noc-header-left">
                <div class="ra-noc-obj-icon">
                    <lightning:icon iconName="custom:custom49" size="medium" />
                </div>
                <div class="ra-noc-header-info">
                    <span class="ra-noc-label">Routing Assignment</span>
                    <span class="ra-noc-name">{!v.recordName}</span>
                </div>
            </div>
            <lightning:button label="Edit" onclick="{!c.handleEdit}" />
        </div>

        <!-- Content -->
        <div class="ra-noc-content">
            <div class="ra-noc-inner">
                <div class="ra-noc-tab-bar">
                    <span class="ra-noc-tab-active">Details</span>
                </div>
                <c:fec_RoutingAssignmentDetailSimple aura:id="detailComponent" recordId="{!v.recordId}" isEditMode="{!v.isEditMode}" onsavesuccess="{!c.handleSaveSuccess}" oncanceledit="{!c.handleCancelEdit}" />
                <div class="ra-noc-history-wrap">
                    <c:fec_RoutingAssignmentHistory aura:id="historyComponent" recordId="{!v.recordId}" />
                </div>
            </div>
        </div>
    </div>
</aura:component>
