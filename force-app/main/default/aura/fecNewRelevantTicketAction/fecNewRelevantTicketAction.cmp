<aura:component implements="lightning:actionOverride,force:hasRecordId,force:hasSObjectName,force:lightningQuickActionWithoutHeader" access="global"
    controller="FEC_RelevantTicketController">

    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="searchTerm" type="String" default="" />
    <aura:attribute name="results" type="List" default="[]" />
    <aura:attribute name="isOpen" type="Boolean" default="false" />
    <aura:attribute name="isLoading" type="Boolean" default="false" />
    <aura:attribute name="selectedId" type="String" default="" />
    <aura:attribute name="selectedLabel" type="String" default="" />
    <aura:attribute name="errorMsg" type="String" default="" />
    <aura:attribute name="isSaving" type="Boolean" default="false" />

    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />

    <div style="background:#f3f2f2;min-height:100vh;padding:0;">
        <div style="max-width:860px;margin:0 auto;background:#fff;">

            <!-- Header -->
            <div style="padding:14px 24px;border-bottom:1px solid #dddbda;text-align:center;">
                <h2 style="font-size:1.125rem;font-weight:700;color:#16325c;margin:0;">{!$Label.c.FEC_RelevantTicket_Title}</h2>
            </div>

            <!-- Body -->
            <div style="padding:16px 24px;">

                <div style="text-align:right;margin-bottom:8px;">
                    <span style="color:#c23934;font-size:0.75rem;">{!$Label.c.FEC_Required_Information}</span>
                </div>

                <!-- Section -->
                <div style="border:1px solid #dddbda;border-radius:8px;margin-bottom:16px;">
                    <div style="background:#f3f2f2;padding:6px 12px;border-bottom:1px solid #dddbda;border-radius:8px 8px 0 0;">
                        <span style="font-weight:600;font-size:0.875rem;color:#3e3e3c;">{!$Label.c.FEC_RelevantTicket_Section_Information}</span>
                    </div>
                    <div style="padding:12px 16px;">
                        <div style="display:flex;align-items:flex-start;">
                            <div style="width:140px;font-size:0.8125rem;color:#3e3e3c;text-align:right;padding-right:12px;padding-top:6px;flex-shrink:0;white-space:nowrap;">
                                <abbr style="color:#c23934;text-decoration:none;" title="required">* </abbr>{!$Label.c.FEC_RelevantTicket_Field_Interaction}
                            </div>
                            <div style="width:320px;position:relative;">

                                <!-- Search input -->
                                <aura:if isTrue="{!!v.selectedId}">
                                    <div style="position:relative;">
                                        <div style="display:flex;align-items:center;border:1px solid #dddbda;border-radius:8px;background:#fff;padding:0 8px;height:32px;overflow:hidden;">
                                            <input type="text"
                                                style="flex:1;border:none;outline:none;font-size:0.875rem;background:transparent;"
                                                placeholder="{!$Label.c.FEC_RelevantTicket_Search_Placeholder}"
                                                value="{!v.searchTerm}"
                                                oninput="{!c.handleInput}"
                                                onfocus="{!c.handleFocus}"
                                                onblur="{!c.handleBlur}"
                                                autocomplete="off" />
                                            <span style="display:flex;align-items:center;color:#706e6b;">
                                                <lightning:icon iconName="utility:search" size="x-small" />
                                            </span>
                                        </div>
                                        <aura:if isTrue="{!v.isOpen}">
                                            <div style="position:absolute;top:100%;left:0;right:0;z-index:9999;background:#fff;border:1px solid #dddbda;border-radius:4px;box-shadow:0 2px 4px rgba(0,0,0,.16);max-height:200px;overflow-y:auto;">
                                                <ul style="list-style:none;margin:0;padding:0;">
                                                    <aura:if isTrue="{!v.isLoading}">
                                                        <li style="padding:8px 12px;">
                                                            <lightning:spinner size="x-small" alternativeText="Đang tìm..." />
                                                        </li>
                                                    </aura:if>
                                                    <aura:if isTrue="{!!v.isLoading}">
                                                        <aura:iteration items="{!v.results}" var="item">
                                                            <li style="padding:8px 12px;cursor:pointer;display:flex;align-items:center;gap:8px;"
                                                                data-id="{!item.id}"
                                                                data-label="{!item.label}"
                                                                onmousedown="{!c.handleSelect}">
                                                                <lightning:icon iconName="standard:case" size="x-small" />
                                                                <span>
                                                                    <div style="font-size:0.875rem;color:#16325c;">{!item.label}</div>
                                                                    <div style="font-size:0.75rem;color:#706e6b;">{!item.sub}</div>
                                                                </span>
                                                            </li>
                                                        </aura:iteration>
                                                        <aura:if isTrue="{!empty(v.results)}">
                                                            <li style="padding:8px 12px;color:#706e6b;font-size:0.875rem;">{!$Label.c.FEC_RelevantTicket_No_Results}</li>
                                                        </aura:if>
                                                    </aura:if>
                                                </ul>
                                            </div>
                                        </aura:if>
                                    </div>
                                </aura:if>

                                <!-- Selected pill -->
                                <aura:if isTrue="{!v.selectedId}">
                                    <div style="display:flex;align-items:center;border:1px solid #dddbda !important;border-radius:8px !important;background:#fff;padding:0 8px;height:32px;box-shadow:none !important;outline:none !important;overflow:hidden;">
                                        <span style="margin-right:6px;display:flex;align-items:center;">
                                            <lightning:icon iconName="standard:case" size="x-small" />
                                        </span>
                                        <span style="flex:1;font-size:0.875rem;color:#16325c;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{!v.selectedLabel}</span>
                                        <button style="background:none;border:none;cursor:pointer;padding:0;margin-left:6px;display:flex;align-items:center;"
                                            onclick="{!c.handleRemove}" title="Remove">
                                            <lightning:icon iconName="utility:close" size="x-small" />
                                        </button>
                                    </div>
                                </aura:if>

                                <aura:if isTrue="{!v.errorMsg}">
                                    <p style="color:#c23934;font-size:0.75rem;margin-top:4px;">{!v.errorMsg}</p>
                                </aura:if>

                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer -->
                <div style="border-top:1px solid #dddbda;padding-top:12px;display:flex;justify-content:center;gap:8px;">
                    <lightning:button label="{!$Label.c.FEC_Button_Cancel}" onclick="{!c.handleCancel}" />
                    <lightning:button label="{!$Label.c.FEC_Button_SaveAndNew}" onclick="{!c.handleSaveNew}" disabled="{!v.isSaving}" />
                    <lightning:button label="{!$Label.c.FEC_Button_Save}" variant="brand" onclick="{!c.handleSave}" disabled="{!v.isSaving}" />
                </div>

            </div>
        </div>
    </div>

</aura:component>