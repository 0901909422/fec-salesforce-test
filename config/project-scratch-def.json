{
    "orgName": "GitLab Pipelines Package Validation",
    "edition": "Developer",
    "language": "en_US",
    "features": [
        "ServiceCloud",
        "Entitlements",
        "LightningServiceConsole"
    ],
    "settings": {
        "entitlementSettings": {
            "enableEntitlements": true,
            "enableMilestoneFeedItem": true
        },
        "languageSettings": {
            "enableTranslationWorkbench": true,
            "enableEndUserLanguages": true
        },
        "omniChannelSettings": {
            "enableOmniChannel": true,
            "enableOmniSkillsRouting": true
        },
        "mobileSettings": {
            "enableS1EncryptedStoragePref2": false
        },
        "enhancedNotesSettings": {
            "enableEnhancedNotes": true
        }
    },
    "objectSettings": {
        "opportunity": {
            "sharingModel": "read"
        }
    }
}
