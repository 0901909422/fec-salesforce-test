<+><template>\n    <template if:false={isEditMode}>\n        <article class=\"slds-card\">\n            <div class=\"slds-card__header slds-grid\">\n                <header class=\"slds-media slds-media_center slds-has-flexi-truncate\">\n                    <div class=\"slds-media__body\">\n                        <h2 class=\"slds-card__header-title\"><span>Detail Information</span></h2>\n                    </div>\n                </header>\n            </div>\n            <div class=\"slds-card__body\">\n                <div class=\"slds-grid slds-wrap detail-grid\">\n                    <div class=\"slds-col slds-size_1-of-2 detail-row\">\n                        <span class=\"detail-label\">GA Name</span>\n                        <span class=\"detail-value\">{record.Name}</span>\n                    </div>\n                    <div class=\"slds-col slds-size_1-of-2 detail-row\">\n                        <span class=\"detail-label\">Customer Type</span>\n                        <span class=\"detail-value\">{record.FEC_Customer_Type__c}</span>\n                    </div>\n                    <div class=\"slds-col slds-size_1-of-2 detail-row\">\n                        <span class=\"detail-label\">Channel</span>\n                        <span class=\"detail-value\">{record.FEC_Channel__c}</span>\n                    </div>\n                    <div class=\"slds-col slds-size_1-of-2 detail-row\">\n                        <span class=\"detail-label\">General Assignment Name</span>\n                        <span class=\"detail-value\">{record.FEC_General_Assignment_Name__c}</span>\n                    </div>\n                    <div class=\"slds-col slds-size_1-of-2 detail-row\">\n                        <span class=\"detail-label\">General Assignment Code</span>\n                        <span class=\"detail-value\">{record.FEC_General_Assignment_Code__c}</span>\n                    </div>\n                    <div class=\"slds-col slds-size_1-of-2 detail-row\">\n                        <span class=\"detail-label\">Active</span>\n                        <span class=\"detail-value\">\n                            <template if:true={record.FEC_Active__c}>\n                                <lightning-icon icon-name=\"utility:check\" size=\"x-small\"></lightning-icon>\n                            </template>\n                            <template if:false={record.FEC_Active__c}>\n                                <span>-</span>\n                            </template>\n                        </span>\n                    </div>\n                </div>\n            </div>\n        </article>\n    </template>\n\n    <template if:true={isEditMode}>\n        <article class=\"slds-card\">\n            <div class=\"slds-card__header slds-grid\">\n                <header class=\"slds-media slds-media_center slds-has-flexi-truncate\">\n                    <div class=\"slds-media__body\">\n                        <h2 class=\"slds-card__header-title\"><span>Detail Information</span></h2>\n                    </div>\n                </header>\n            </div>\n            <div class=\"slds-card__body slds-card__body_inner\">\n                <div class=\"slds-grid slds-gutters slds-wrap\">\n                    <!-- Customer Type -->\n                    <div class=\"slds-col slds-size_1-of-2 slds-m-bottom_small\">\n                        <lightning-combobox\n                            label=\"Customer Type\"\n                            value={editCustomerType}\n                            options={customerTypeOptions}\n                            onchange={handleCustomerTypeChange}>\n                        </lightning-combobox>\n                    </div>\n\n                    <!-- Channel search+tag -->\n                    <div class=\"slds-col slds-size_1-of-2 slds-m-bottom_small\">\n                        <div class=\"slds-form-element\">\n                            <label class=\"slds-form-element__label\">Channel</label>\n                            <div class=\"slds-form-element__control\">\n                                <div class={channelComboboxClass}>\n                                    <div class=\"slds-combobox__form-element slds-input-has-icon slds-input-has-icon_right\" role=\"none\">\n                                        <input type=\"text\" class=\"slds-input slds-combobox__input\"\n                                            placeholder=\"Search Channel\"\n                                            value={channelSearchTerm}\n                                            oninput={handleChannelSearch}\n                                            onfocus={handleChannelFocus}\n                                            onblur={handleChannelBlur} />\n                                        <span class=\"slds-icon_container slds-input__icon slds-input__icon_right\">\n                                            <lightning-icon icon-name=\"utility:search\" size=\"x-small\"></lightning-icon>\n                                        </span>\n                                    </div>\n                                    <template if:true={showChannelDropdown}>\n                                        <div class=\"slds-dropdown slds-dropdown_length-5 slds-dropdown_fluid\" role=\"listbox\">\n                                            <ul class=\"slds-listbox slds-listbox_vertical\" role=\"presentation\">\n                                                <template for:each={filteredChannelOptions} for:item=\"opt\">\n                                                    <li key={opt.value} role=\"presentation\" class=\"slds-listbox__item\">\n                                                        <div class=\"slds-media slds-listbox__option slds-listbox__option_plain slds-media_small\"\n                                                            role=\"option\" data-value={opt.value} onclick={handleChannelSelect}>\n                                                            <span class=\"slds-media__body\">\n                                                                <span class=\"slds-truncate\">{opt.label}</span>\n                                                            </span>\n                                                        </div>\n                                                    </li>\n                                                </template>\n                                            </ul>\n                                        </div>\n                                    </template>\n                                </div>\n                                <template if:true={selectedChannels.length}>\n                                    <div class=\"slds-m-top_x-small\">\n                                        <template for:each={selectedChannels} for:item=\"ch\">\n                                            <lightning-pill key={ch} label={ch} name={ch} onremove={handleChannelRemove}></lightning-pill>\n                                        </template>\n                                    </div>\n                                </template>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- General Assignment Name search+tag -->\n                    <div class=\"slds-col slds-size_1-of-2 slds-m-bottom_small\">\n                        <div class=\"slds-form-element\">\n                            <label class=\"slds-form-element__label\">General Assignment Name</label>\n                            <div class=\"slds-form-element__control\">\n                                <div class={gaComboboxClass}>\n                                    <div class=\"slds-combobox__form-element slds-input-has-icon slds-input-has-icon_right\" role=\"none\">\n                                        <input type=\"text\" class=\"slds-input slds-combobox__input\"\n                                            placeholder=\"Search General Assignment Name\"\n                                            value={gaSearchTerm}\n                                            oninput={handleGASearch}\n                                            onfocus={handleGAFocus}\n                                            onblur={handleGABlur} />\n                                        <span class=\"slds-icon_container slds-input__icon slds-input__icon_right\">\n                                            <lightning-icon icon-name=\"utility:search\" size=\"x-small\"></lightning-icon>\n                                        </span>\n                                    </div>\n                                    <template if:true={showGADropdown}>\n                                        <div class=\"slds-dropdown slds-dropdown_length-5 slds-dropdown_fluid\" role=\"listbox\">\n                                            <ul class=\"slds-listbox slds-listbox_vertical\" role=\"presentation\">\n                                                <template for:each={filteredGAOptions} for:item=\"opt\">\n                                                    <li key={opt.value} role=\"presentation\" class=\"slds-listbox__item\">\n                                                        <div class=\"slds-media slds-listbox__option slds-listbox__option_plain slds-media_small\"\n                                                            role=\"option\" data-value={opt.value} onclick={handleGASelect}>\n                                                            <span class=\"slds-media__body\">\n                                                                <span class=\"slds-truncate\">{opt.label}</span>\n                                                            </span>\n                                                        </div>\n                                                    </li>\n                                                </template>\n                                            </ul>\n                                        </div>\n                                    </template>\n                                </div>\n                                <template if:true={selectedGANames.length}>\n                                    <div class=\"slds-m-top_x-small\">\n                                        <template for:each={selectedGANames} for:item=\"gaName\">\n                                            <lightning-pill key={gaName} label={gaName} name={gaName} onremove={handleGARemove}></lightning-pill>\n                                        </template>\n                                    </div>\n                                </template>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- GA Code: editable, auto-filled when GA Name selected -->\n                    <div class=\"slds-col slds-size_1-of-2 slds-m-bottom_small\">\n                        <lightning-input label=\"General Assignment Code\" value={gaCodeDisplay} onchange={handleGACodeChange}></lightning-input>\n                    </div>\n\n                    <!-- Active -->\n                    <div class=\"slds-col slds-size_1-of-1 slds-m-bottom_small\">\n                        <div class=\"slds-form-element\">\n                            <label class=\"slds-form-element__label\">Active</label>\n                            <div class=\"slds-form-element__control\">\n                                <input type=\"checkbox\" checked={editActive} onchange={handleActiveChange} />\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"slds-text-align_center slds-m-top_medium\">\n                    <lightning-button label=\"Cancel\" onclick={handleCancel} class=\"slds-m-right_small\"></lightning-button>\n                    <lightning-button variant=\"brand\" label=\"Save\" onclick={handleSave}></lightning-button>\n                </div>\n            </div>\n        </article>\n    </template>\n</template>\n
