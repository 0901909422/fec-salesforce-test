@@ -45,3 +45,50 @@
     font-size: 0.8125rem;
     color: #706e6b;
 }
+
+/* Edit mode 2-column grid */
+.ga-edit-grid {
+    display: flex;
+    flex-wrap: wrap;
+    gap: 0.75rem 1rem;
+    padding: 0.5rem 0;
+    width: 100%;
+}
+.ga-edit-col {
+    width: calc(50% - 0.5rem);
+    flex: 0 0 calc(50% - 0.5rem);
+    max-width: calc(50% - 0.5rem);
+    min-width: 0;
+    box-sizing: border-box;
+}
+
+/* 4-column form grid: label | input | label | input */
+.form-grid {
+    display: grid;
+    grid-template-columns: 25% 25% 25% 25%;
+    gap: 0.75rem 0;
+    align-items: start;
+    padding: 0.5rem 0;
+    width: 100%;
+}
+.form-label {
+    font-size: 0.8125rem;
+    font-weight: 700;
+    color: #3e3e3c;
+    padding-top: 0.4rem;
+    white-space: nowrap;
+}
+.form-value {
+    font-size: 0.8125rem;
+    min-width: 0;
+}
+.ga-search-wrap { position: relative; }
+.ga-dropdown {
+    position: absolute; top: 100%; left: 0; right: 0;
+    z-index: 9001; background: #fff;
+    border: 1px solid #dddbda; border-radius: 0.25rem;
+    box-shadow: 0 2px 3px rgba(0,0,0,.16);
+    max-height: 200px; overflow-y: auto;
+}
+.ga-option { cursor: pointer; padding: 0.5rem 0.75rem; list-style: none; font-size: 0.875rem; }
+.ga-option:hover { background: #f3f3f3; }
