+String accountNumber = '0001500020000011777';
+
+// 1. Tìm Customer History records
+List<FEC_Customer_History__c> histories = [
+    SELECT Id, Name, FEC_Account_Number__c, FEC_CIF_Number__c,
+           FEC_Work_Phone__c, FEC_Case__c, CreatedDate, LastModifiedDate
+    FROM FEC_Customer_History__c
+    WHERE FEC_Account_Number__c = :accountNumber
+    ORDER BY CreatedDate DESC
+    LIMIT 5
+];
+System.debug('Customer Histories found: ' + histories.size());
+for (FEC_Customer_History__c h : histories) {
+    System.debug('History Id: ' + h.Id + ' | CIF: ' + h.FEC_CIF_Number__c + ' | Phone: ' + h.FEC_Work_Phone__c + ' | CaseId: ' + h.FEC_Case__c + ' | Created: ' + h.CreatedDate);
+}
+
+// 2. Tìm Case records liên quan
+List<Case> cases = [
+    SELECT Id, CaseNumber, Subject, Status, FEC_Account_Number__c,
+           FEC_CIF_Number__c, FEC_Customer_Name__c, FEC_Search_Account_Number__c,
+           CreatedDate
+    FROM Case
+    WHERE FEC_Account_Number__c = :accountNumber
+       OR FEC_Search_Account_Number__c = :accountNumber
+    ORDER BY CreatedDate DESC
+    LIMIT 5
+];
+System.debug('Cases found: ' + cases.size());
+for (Case c : cases) {
+    System.debug('Case: ' + c.CaseNumber + ' | Id: ' + c.Id + ' | CustomerName: ' + c.FEC_Customer_Name__c + ' | CIF: ' + c.FEC_CIF_Number__c + ' | Status: ' + c.Status);
