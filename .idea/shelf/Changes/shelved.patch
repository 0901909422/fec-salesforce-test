@@ -0,0 +1,51 @@
+/**
+ * Script giả lập tạo Interaction Case kênh Email - Ubank
+ * Chạy bằng: sf apex run --file scripts/simulate_ubank_email_case.apex
+ *
+ * Tạo:
+ *   1. Interaction Case (RecordType = Interaction, Channel = Email, Send To = dichvukhachhang@ubank.vn)
+ *   2. EmailMessage incoming (giả lập email KH gửi vào)
+ */
+
+// ── 1. Lấy RecordType Interaction ──────────────────────────────────────────
+Id interactionRTId = Schema.SObjectType.Case
+    .getRecordTypeInfosByDeveloperName()
+    .get('Interaction')
+    .getRecordTypeId();
+
+// ── 2. Lấy current user để assign ──────────────────────────────────────────
+Id currentUserId = UserInfo.getUserId();
+String currentUserEmail = UserInfo.getUserEmail();
+
+// ── 3. Tạo Interaction Case ─────────────────────────────────────────────────
+Case interactionCase = new Case();
+interactionCase.RecordTypeId       = interactionRTId;
+interactionCase.Status             = 'Open';
+interactionCase.FEC_Channel__c     = 'Email';
+interactionCase.FEC_Interaction_Subchannel__c = 'Incoming Email';
+interactionCase.FEC_Interaction_View_Mode__c  = 'handling';
+interactionCase.FEC_Send_To__c     = 'dichvukhachhang@ubank.vn';
+interactionCase.FEC_Interaction_Email__c      = 'testcustomer@gmail.com';
+interactionCase.Subject            = '[TEST] Yêu cầu hỗ trợ từ khách hàng Ubank';
+interactionCase.OwnerId            = currentUserId;
+insert interactionCase;
+
+System.debug('✅ Interaction Case created: ' + interactionCase.Id);
+
+// ── 4. Tạo EmailMessage incoming (giả lập email KH gửi vào) ────────────────
+EmailMessage em = new EmailMessage();
+em.ParentId     = interactionCase.Id;
+em.FromAddress  = 'testcustomer@gmail.com';
+em.FromName     = 'Test Customer';
+em.ToAddress    = 'dichvukhachhang@ubank.vn';
+em.Subject      = '[TEST] Yêu cầu hỗ trợ từ khách hàng Ubank';
+em.TextBody     = 'Xin chào, tôi cần hỗ trợ về tài khoản Ubank của mình. Vui lòng liên hệ lại với tôi.';
+em.HtmlBody     = '<p>Xin chào, tôi cần hỗ trợ về tài khoản Ubank của mình.</p><p>Vui lòng liên hệ lại với tôi.</p>';
+em.Incoming     = true;
+em.MessageDate  = DateTime.now();
+em.Status       = '0'; // New
+insert em;
+
+System.debug('✅ EmailMessage created: ' + em.Id);
+System.debug('🔗 Case URL: /lightning/r/Case/' + interactionCase.Id + '/view');
+System.debug('📧 From: testcustomer@gmail.com → To: dichvukhachhang@ubank.vn');
