diff --git a/scripts/test_ubank_send.apex b/scripts/test_ubank_send.apex
new file mode 100644
--- /dev/null	(date 1774862778612)
+++ b/scripts/test_ubank_send.apex	(date 1774862778612)
@@ -0,0 +1,66 @@
+// Test gửi email với From/To giống hệt UI
+String caseId = '500Az00000NC4CHIA1'; // [TEST] Yêu cầu hỗ trợ từ khách hàng Ubank
+String fromEmail = 'dichvukhachhang@ubank.vn';
+String toEmail = 'testcustomer@gmail.com';
+
+System.debug('=== TEST UBANK SEND ===');
+System.debug('From: ' + fromEmail);
+System.debug('To: ' + toEmail);
+
+// 1. Check OrgWide có dichvukhachhang@ubank.vn không
+List<OrgWideEmailAddress> owas = [SELECT Id, Address, DisplayName FROM OrgWideEmailAddress];
+System.debug('OrgWide count: ' + owas.size());
+OrgWideEmailAddress matchOWA = null;
+for (OrgWideEmailAddress o : owas) {
+    System.debug('  OWA: ' + o.Address + ' | ' + o.DisplayName);
+    if (o.Address != null && o.Address.equalsIgnoreCase(fromEmail)) {
+        matchOWA = o;
+    }
+}
+
+// 2. Check EmailRoutingAddress có dichvukhachhang@ubank.vn không
+List<SObject> routings = Database.query('SELECT Id, Address, PersonalName FROM EmailRoutingAddress LIMIT 20');
+SObject matchRouting = null;
+for (SObject r : routings) {
+    String addr = (String)r.get('Address');
+    System.debug('  Routing: ' + r.get('PersonalName') + ' <' + addr + '>');
+    if (addr != null && addr.equalsIgnoreCase(fromEmail)) matchRouting = r;
+}
+
+if (matchOWA != null) {
+    System.debug('✅ Found in OrgWide: ' + matchOWA.Address);
+} else if (matchRouting != null) {
+    System.debug('⚠️ Found in EmailRoutingAddress only (not OrgWide): ' + matchRouting.get('Address'));
+} else {
+    System.debug('❌ dichvukhachhang@ubank.vn NOT FOUND in OrgWide or Routing!');
+}
+
+// 3. Gửi email
+Messaging.SingleEmailMessage mail = new Messaging.SingleEmailMessage();
+mail.setToAddresses(new List<String>{ toEmail });
+mail.setSubject('TEST FEC Send - ' + DateTime.now().format('dd/MM HH:mm:ss'));
+mail.setHtmlBody('<p>Test email từ FEC - From: ' + fromEmail + '</p>');
+mail.setSaveAsActivity(false);
+
+if (matchOWA != null) {
+    mail.setOrgWideEmailAddressId(matchOWA.Id);
+    System.debug('Sending via OrgWide...');
+} else {
+    mail.setReplyTo(fromEmail);
+    System.debug('Sending via setReplyTo (no OrgWide match)...');
+}
+
+Messaging.SendEmailResult[] results = Messaging.sendEmail(new List<Messaging.SingleEmailMessage>{ mail });
+Messaging.SendEmailResult r = results[0];
+if (r.isSuccess()) {
+    System.debug('✅ SENT OK');
+} else {
+    System.debug('❌ FAILED:');
+    for (Messaging.SendEmailError e : r.getErrors()) {
+        System.debug('  ' + e.getStatusCode() + ': ' + e.getMessage());
+    }
+}
+
+// 4. Check current user (email thực sự gửi từ đây nếu không có OrgWide)
+User u = [SELECT Email, Name FROM User WHERE Id = :UserInfo.getUserId()];
+System.debug('Actual sender (current user): ' + u.Name + ' <' + u.Email + '>');
