+// Kiểm tra email thực sự gửi từ đâu khi không có OrgWide
+// Và check EmailMessage đã được insert chưa
+String caseId = '500Az00000NCST8IAP';
+
+// 1. Check OrgWide
+List<OrgWideEmailAddress> owas = [SELECT Id, Address, DisplayName FROM OrgWideEmailAddress];
+System.debug('OrgWide count: ' + owas.size());
+
+// 2. Check current user email
+User u = [SELECT Id, Email, Name FROM User WHERE Id = :UserInfo.getUserId() LIMIT 1];
+System.debug('Current user: ' + u.Name + ' | Email: ' + u.Email);
+
+// 3. Gửi email với saveAsActivity=true + setWhatId để track được
+Messaging.SingleEmailMessage mail = new Messaging.SingleEmailMessage();
+mail.setToAddresses(new List<String>{ 'minhtung2108@gmail.com' });
+mail.setSubject('FEC DEBUG - Check From Address ' + DateTime.now().format('HH:mm:ss'));
+mail.setHtmlBody('<p>Debug email - kiểm tra From address thực tế.</p>');
+mail.setSaveAsActivity(true);
+mail.setWhatId(caseId);
+// Không set OrgWide, không set ReplyTo → gửi từ current user
+
+Messaging.SendEmailResult[] r1 = Messaging.sendEmail(new List<Messaging.SingleEmailMessage>{ mail });
+System.debug('Test 1 (no from set) - Success: ' + r1[0].isSuccess());
+if (!r1[0].isSuccess()) {
+    for (Messaging.SendEmailError e : r1[0].getErrors()) System.debug('  Error: ' + e.getMessage());
+}
+
+// 4. Gửi email với setReplyTo = routing address (như code hiện tại)
+Messaging.SingleEmailMessage mail2 = new Messaging.SingleEmailMessage();
+mail2.setToAddresses(new List<String>{ 'minhtung2108@gmail.com' });
+mail2.setSubject('FEC DEBUG - With ReplyTo ' + DateTime.now().format('HH:mm:ss'));
+mail2.setHtmlBody('<p>Debug email - với setReplyTo = tsalesforce63@gmail.com</p>');
+mail2.setReplyTo('tsalesforce63@gmail.com');
+mail2.setSaveAsActivity(false);
+
+Messaging.SendEmailResult[] r2 = Messaging.sendEmail(new List<Messaging.SingleEmailMessage>{ mail2 });
+System.debug('Test 2 (setReplyTo) - Success: ' + r2[0].isSuccess());
+if (!r2[0].isSuccess()) {
+    for (Messaging.SendEmailError e : r2[0].getErrors()) System.debug('  Error: ' + e.getMessage());
+}
+
+// 5. Check EmailMessage records sau khi gửi
+System.debug('--- EmailMessages on case ---');
+List<EmailMessage> msgs = [
+    SELECT Id, FromAddress, ToAddress, Subject, Incoming, Status, MessageDate
+    FROM EmailMessage WHERE ParentId = :caseId
+    ORDER BY MessageDate DESC LIMIT 5
+];
+for (EmailMessage m : msgs) {
+    System.debug((m.Incoming ? 'IN ' : 'OUT') + ' | From: ' + m.FromAddress + ' | Status: ' + m.Status + ' | ' + m.Subject);
+}
