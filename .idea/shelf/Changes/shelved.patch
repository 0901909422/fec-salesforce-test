+                <template if:true={hasWatchers}>
+                    <div class="slds-text-align_center slds-m-top_small">
+                        <span role="button" class="view-all-link" tabindex="0" onclick={handleViewAll} onkeydown={handleViewAllKeydown}>View All</span>
+                    </div>
+                </template>
+            </template>
+        </div>
+    </lightning-card>
+</template>
