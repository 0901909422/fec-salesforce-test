+List<Case> cases = [
+    SELECT Id, Subject, Status, FEC_Send_To__c, FEC_Interaction_Email__c
+    FROM Case
+    WHERE FEC_Send_To__c != null
+    ORDER BY CreatedDate DESC
+    LIMIT 5
+];
+for(Case c : cases) {
+    System.debug('Case: ' + c.Id + ' | ' + c.Subject + ' | Status: ' + c.Status + ' | SendTo: ' + c.FEC_Send_To__c + ' | InteractionEmail: ' + c.FEC_Interaction_Email__c);
+}
+if (cases.isEmpty()) {
+    System.debug('No cases with FEC_Send_To__c found. Trying all recent cases...');
+    List<Case> all = [SELECT Id, Subject, Status FROM Case ORDER BY CreatedDate DESC LIMIT 5];
+    for(Case c : all) { System.debug('Case: ' + c.Id + ' | ' + c.Subject + ' | Status: ' + c.Status); }
+}
