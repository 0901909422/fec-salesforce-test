diff --git a/scripts/test_send_button.apex b/scripts/test_send_button.apex
new file mode 100644
--- /dev/null	(date 1774862778564)
+++ b/scripts/test_send_button.apex	(date 1774862778564)
@@ -0,0 +1,110 @@
+/**
+ * Test nút Send - simulate chính xác flow của FEC_CustomEmailService.sendEmail()
+ * Chạy trong Developer Console > Execute Anonymous
+ * Thay caseId và toEmail bên dưới
+ */
+String caseId = '500Az00000NCST8IAP'; // PL 27/03 test04 | Status: Pending
+String toEmail = 'minhtung2108@gmail.com'; // ← thay bằng email nhận test
+
+System.debug('=== TEST SEND BUTTON FLOW ===');
+
+// 1. Kiểm tra Case
+Case c;
+try {
+    c = [SELECT Id, Status, FEC_Interaction_Status__c, OwnerId, Subject FROM Case WHERE Id = :caseId LIMIT 1];
+    System.debug('✅ Case found: ' + c.Subject + ' | Status: ' + c.Status);
+} catch(Exception e) {
+    System.debug('❌ Case not found: ' + e.getMessage());
+    return;
+}
+
+// 2. Kiểm tra blocked status
+Set<String> BLOCKED = new Set<String>{'Closed','Resolved','Cancelled'};
+if (BLOCKED.contains(c.Status)) {
+    System.debug('❌ BLOCKED: Case status = ' + c.Status);
+    return;
+}
+System.debug('✅ Status OK: ' + c.Status);
+
+// 3. Kiểm tra OrgWideEmailAddress
+List<OrgWideEmailAddress> owas = [SELECT Id, Address, DisplayName FROM OrgWideEmailAddress];
+System.debug('OrgWide count: ' + owas.size());
+for (OrgWideEmailAddress o : owas) {
+    System.debug('  OWA: ' + o.DisplayName + ' <' + o.Address + '> | Id: ' + o.Id);
+}
+
+// 4. Kiểm tra EmailRoutingAddress
+List<SObject> routings;
+try {
+    routings = Database.query('SELECT Id, Address, PersonalName FROM EmailRoutingAddress LIMIT 10');
+    System.debug('EmailRoutingAddress count: ' + routings.size());
+    for (SObject r : routings) {
+        System.debug('  Routing: ' + r.get('PersonalName') + ' <' + r.get('Address') + '>');
+    }
+} catch(Exception e) {
+    System.debug('EmailRoutingAddress query failed: ' + e.getMessage());
+}
+
+// 5. Lấy fromEmail từ Case (giống getInteractionEmail)
+Case cFull = [SELECT FEC_Send_To__c, FEC_Interaction_Email__c, FEC_Interaction__c FROM Case WHERE Id = :caseId LIMIT 1];
+String fromEmail = cFull.FEC_Send_To__c;
+System.debug('fromEmail from Case.FEC_Send_To__c: ' + fromEmail);
+
+// 6. Thử gửi email giống hệt sendEmail() trong service
+Messaging.SingleEmailMessage mail = new Messaging.SingleEmailMessage();
+mail.setToAddresses(new List<String>{ toEmail });
+mail.setSubject('TEST SEND BUTTON - ' + DateTime.now().format('dd/MM/yyyy HH:mm:ss'));
+mail.setHtmlBody('<p>Test từ script - simulate nút Send.</p><p>Case: ' + c.Subject + '</p>');
+mail.setSaveAsActivity(false);
+
+// Thử set OrgWide nếu có
+Boolean foundOWA = false;
+if (String.isNotBlank(fromEmail)) {
+    for (OrgWideEmailAddress owa : owas) {
+        if (owa.Address != null && owa.Address.equalsIgnoreCase(fromEmail)) {
+            mail.setOrgWideEmailAddressId(owa.Id);
+            System.debug('✅ Using OrgWide: ' + owa.Address);
+            foundOWA = true;
+            break;
+        }
+    }
+    if (!foundOWA) {
+        mail.setReplyTo(fromEmail);
+        System.debug('⚠️ fromEmail not in OrgWide → setReplyTo only: ' + fromEmail);
+    }
+} else {
+    System.debug('⚠️ fromEmail is blank → sending from current user');
+}
+
+// 7. Gửi
+try {
+    List<Messaging.SendEmailResult> results = Messaging.sendEmail(
+        new List<Messaging.SingleEmailMessage>{ mail }
+    );
+    Messaging.SendEmailResult r = results[0];
+    if (r.isSuccess()) {
+        System.debug('✅ EMAIL SENT SUCCESSFULLY to ' + toEmail);
+    } else {
+        System.debug('❌ SEND FAILED:');
+        for (Messaging.SendEmailError err : r.getErrors()) {
+            System.debug('  Error code: ' + err.getStatusCode());
+            System.debug('  Error msg:  ' + err.getMessage());
+        }
+    }
+} catch(Exception e) {
+    System.debug('❌ EXCEPTION: ' + e.getTypeName() + ': ' + e.getMessage());
+    System.debug('Stack: ' + e.getStackTraceString());
+}
+
+// 8. Kiểm tra EmailMessage records gần đây
+List<EmailMessage> recent = [
+    SELECT Id, FromAddress, ToAddress, Subject, MessageDate, Status
+    FROM EmailMessage
+    WHERE ParentId = :caseId
+    ORDER BY MessageDate DESC
+    LIMIT 5
+];
+System.debug('Recent EmailMessages on case: ' + recent.size());
+for (EmailMessage em : recent) {
+    System.debug('  [' + em.Status + '] ' + em.Subject + ' | From: ' + em.FromAddress + ' | Date: ' + em.MessageDate);
+}
