diff --git a/scripts/debug_raw_response.apex b/scripts/debug_raw_response.apex
new file mode 100644
--- /dev/null	(date 1774862778120)
+++ b/scripts/debug_raw_response.apex	(date 1774862778120)
@@ -0,0 +1,34 @@
+// Xem raw XML response từ API GetCustomerList
+FEC_API_Setting__c apiSetting = FEC_API_Setting__c.getOrgDefaults();
+FEC_API_Config__mdt apiConfig = FEC_API_Config__mdt.getInstance('FEC_Get_Customer_List');
+
+String endpoint = apiSetting?.FEC_Call_Mock__c
+    ? FEC_MockupEndpoint.GET_CUSTOMER_LIST_ENDPOINT_MOCKUP
+    : (apiSetting?.FEC_Endpoint__c + apiConfig?.FEC_Endpoint__c);
+
+System.debug('Endpoint: ' + endpoint);
+System.debug('Is Mock: ' + apiSetting?.FEC_Call_Mock__c);
+
+// Build SOAP body thủ công
+String transId = '12345678-1234-1234-1234-123456789012';
+String dateTimeStr = Datetime.now().format('yyyy-MM-dd\'T\'HH:mm:ss');
+String soapBody = '<?xml version="1.0"?>'
+    + '<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:cif="http://fecredit.com.vn/CIF_CustomerSearch">'
+    + '<soapenv:Header/><soapenv:Body>'
+    + '<ns1:GetCustomerList xmlns:ns1="http://fecredit.com.vn/CIF_CustomerSearch">'
+    + '<Sys><TransID>' + transId + '</TransID><RequestorID>PEGA-CSM</RequestorID><DateTime>' + dateTimeStr + '</DateTime></Sys>'
+    + '<Parameters><AccountNumber>0001500020000011777</AccountNumber></Parameters>'
+    + '</ns1:GetCustomerList></soapenv:Body></soapenv:Envelope>';
+
+HttpRequest req = new HttpRequest();
+req.setEndpoint(endpoint);
+req.setMethod('POST');
+req.setHeader('Content-Type', 'text/xml; charset=utf-8');
+if (apiConfig?.FEC_SOAP_Action__c != null) req.setHeader('SOAPAction', apiConfig.FEC_SOAP_Action__c);
+req.setBody(soapBody);
+req.setTimeout(30000);
+
+HttpResponse res = new Http().send(req);
+System.debug('Status: ' + res.getStatusCode());
+System.debug('RAW RESPONSE:');
+System.debug(res.getBody());
