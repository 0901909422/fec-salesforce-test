+// Simulate chính xác flow của nút Send trên UI
+// Lấy Case có tsalesforce63@gmail.com làm FEC_Send_To__c
+List<Case> cases = [
+    SELECT Id, Subject, Status, FEC_Send_To__c, FEC_Interaction_Email__c
+    FROM Case
+    WHERE FEC_Send_To__c = 'tsalesforce63@gmail.com'
+    ORDER BY CreatedDate DESC
+    LIMIT 1
+];
+
+if (cases.isEmpty()) {
+    System.debug('❌ No case with FEC_Send_To__c = tsalesforce63@gmail.com');
+    // List all recent cases
+    List<Case> all = [SELECT Id, CaseNumber, FEC_Send_To__c, FEC_Interaction_Email__c FROM Case ORDER BY CreatedDate DESC LIMIT 5];
+    for (Case c : all) System.debug('Case: ' + c.CaseNumber + ' | SendTo: ' + c.FEC_Send_To__c + ' | InteractionEmail: ' + c.FEC_Interaction_Email__c);
+    return;
+}
+
+Case c = cases[0];
+System.debug('Case: ' + c.Subject + ' | SendTo: ' + c.FEC_Send_To__c + ' | InteractionEmail: ' + c.FEC_Interaction_Email__c);
+
+// Simulate sendEmail call
+String fromEmail = c.FEC_Send_To__c;
+String toEmail = c.FEC_Interaction_Email__c;
+
+// Check OrgWide
+List<OrgWideEmailAddress> owas = [SELECT Id, Address FROM OrgWideEmailAddress WHERE Address = :fromEmail LIMIT 1];
+System.debug('OrgWide for ' + fromEmail + ': ' + owas.size());
+
+// Gửi
+Messaging.SingleEmailMessage mail = new Messaging.SingleEmailMessage();
+mail.setToAddresses(new List<String>{ toEmail });
+mail.setSubject('UI Send Test - ' + DateTime.now().format('HH:mm:ss'));
+mail.setHtmlBody('<p>Test từ UI flow. From: ' + fromEmail + ' To: ' + toEmail + '</p>');
+mail.setSaveAsActivity(false);
+
+if (!owas.isEmpty()) {
+    mail.setOrgWideEmailAddressId(owas[0].Id);
+    System.debug('✅ Sending via OrgWide: ' + fromEmail);
+} else {
+    mail.setReplyTo(fromEmail);
+    System.debug('⚠️ No OrgWide - setReplyTo: ' + fromEmail);
+}
+
+Messaging.SendEmailResult[] r = Messaging.sendEmail(new List<Messaging.SingleEmailMessage>{ mail });
+System.debug('Success: ' + r[0].isSuccess());
+if (!r[0].isSuccess()) {
+    for (Messaging.SendEmailError e : r[0].getErrors()) System.debug('Error: ' + e.getMessage());
+}
