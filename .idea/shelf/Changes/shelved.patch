@@ -0,0 +1,53 @@
+/**
+ * Giả lập Genesys tạo Interaction Case kênh Email - FEC
+ * Gọi đúng FEC_CreateInteractionGenesys.createInteraction() như Genesys thật
+ * Chạy: sf apex run --file scripts/simulate_genesys_email_case.apex
+ */
+
+FEC_CreateInteractionGenesys.GenesysRequest req = new FEC_CreateInteractionGenesys.GenesysRequest();
+req.genesysInteractionID = 'EMAIL' + String.valueOf(Math.abs(Crypto.getRandomInteger())).left(10);
+req.type                 = 'InboundRinging';   // CHANNEL_INBOUND_API
+req.method               = 'Auto';             // AUTO_METHOD → viewMode = handling
+req.agentID              = UserInfo.getUserId();
+req.phoneNumber          = null;
+req.nationalID           = null;
+req.contractNum          = null;
+req.cardAccountNum       = null;
+req.campaignName         = 'Email FEC Test';
+
+FEC_CreateInteractionGenesys.InteractionResult result =
+    FEC_CreateInteractionGenesys.createInteraction(req);
+
+System.debug('isSuccess: ' + result.isSuccess);
+System.debug('message:   ' + result.message);
+System.debug('recordId:  ' + result.recordId);
+
+if (result.isSuccess && result.recordId != null) {
+    // Patch thêm Email fields (Genesys truyền qua email-to-case)
+    update new Case(
+        Id                          = result.recordId,
+        FEC_Channel__c              = 'Email',
+        FEC_Interaction_Subchannel__c = 'Incoming Email',
+        FEC_Interaction_Email__c    = 'testcustomer@gmail.com',
+        FEC_Send_To__c              = 'dichvukhachhang@fecredit.com.vn'
+    );
+
+    // Tạo EmailMessage incoming giả lập
+    EmailMessage em = new EmailMessage();
+    em.ParentId    = result.recordId;
+    em.FromAddress = 'testcustomer@gmail.com';
+    em.FromName    = 'Test Customer FEC';
+    em.ToAddress   = 'dichvukhachhang@fecredit.com.vn';
+    em.Subject     = '[TEST-FEC] Yêu cầu hỗ trợ từ khách hàng FECredit';
+    em.TextBody    = 'Xin chào, tôi cần hỗ trợ về khoản vay FECredit. Vui lòng liên hệ lại.';
+    em.HtmlBody    = '<p>Xin chào, tôi cần hỗ trợ về khoản vay FECredit.</p>';
+    em.Incoming    = true;
+    em.MessageDate = DateTime.now();
+    em.Status      = '0';
+    insert em;
+
+    System.debug('✅ EmailMessage: ' + em.Id);
+    System.debug('🔗 Case URL: /lightning/r/Case/' + result.recordId + '/view');
+    System.debug('📧 From: testcustomer@gmail.com → To: dichvukhachhang@fecredit.com.vn');
+    System.debug('🆔 Genesys ID: ' + req.genesysInteractionID);
+}
