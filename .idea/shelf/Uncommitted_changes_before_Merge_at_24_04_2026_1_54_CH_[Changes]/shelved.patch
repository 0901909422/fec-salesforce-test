+      }
+      Map<String, Id> queueNameToId = new Map<String, Id>();
+      Map<String, String> queueNameToName = new Map<String, String>();
+      for (Group g : [SELECT Id, Name FROM Group WHERE Name IN :queueNames AND Type = 'Queue']) {
